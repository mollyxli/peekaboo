{
  "name": "pixel-pal",
  "version": "1.0.1",
  "description": "A pixel art desktop pet that reminds you to take breaks",
  "author": "Molly Li",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n \"VITE,ELECTRON\" -c \"cyan,yellow\" \"vite\" \"node scripts/start-electron.js\"",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production electron .",
    "dist": "vite build && electron-builder",
    "dist:mac": "vite build && electron-builder --mac"
  },
  "build": {
    "appId": "com.mollyxli.peekaboo",
    "productName": "Peekaboo",
    "directories": {
      "output": "release"
    },
    "afterPack": "./scripts/afterPack.js",
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        },
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "dmg": {
      "title": "Peekaboo ${version}"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.2.2",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.3",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "electron-store": "^7.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.2"
  }
}
