{
  "name": "pixel-pal",
  "version": "1.0.0",
  "description": "A pixel art desktop pet that reminds you to take breaks",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n \"VITE,ELECTRON\" -c \"cyan,yellow\" \"vite\" \"node scripts/start-electron.js\"",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production electron ."
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.3",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "electron": "^28.2.2",
    "electron-store": "^7.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.2"
  }
}
